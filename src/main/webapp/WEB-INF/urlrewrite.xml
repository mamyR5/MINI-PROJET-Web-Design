<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE urlrewrite PUBLIC "-//tuckey.org//DTD UrlRewrite 4.0//EN"
        "http://www.tuckey.org/res/dtds/urlrewrite4.0.dtd">

<urlrewrite>

    <rule>
        <from>^/test/([0-9]+)-(.*)$</from>
        <to>/test?id=$1</to>
    </rule>

    <rule>
        <from>^/admin/login$</from>
        <to type="forward">/login</to>
    </rule>
    <rule>
        <from>^/article/([0-9]+)-(.*)$</from>
        <to>/article?id=$1</to>
    </rule>
    <rule>
        <from>^/categorie/([0-9]+)-(.*)$</from>
        <to>/categorie?id=$1</to>
    </rule>
</urlrewrite>