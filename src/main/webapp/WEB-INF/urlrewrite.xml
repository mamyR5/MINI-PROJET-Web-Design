<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE urlrewrite PUBLIC "-//tuckey.org//DTD UrlRewrite 4.0//EN"
        "http://www.tuckey.org/res/dtds/urlrewrite4.0.dtd">

<urlrewrite>

    <rule>
        <from>^/test/([0-9]+)-(.*)$</from>
        <to>/test?id=$1</to>
    </rule>

    <rule>
        <from>^/test/([0-9]+)-(.*)$</from>
        <to>/test?id=$1</to>
    </rule>

    <rule>
        <from>^/admin/login$</from>
        <to type="forward">/login</to>
    </rule>

    <rule>
        <from>^/admin/redaction$</from>
        <to type="forward">/redaction</to>
    </rule>

    <rule>
        <from>^/admin/home$</from>
        <to type="forward">/home</to>
    </rule>

    <rule>
        <from>^/admin/article$</from>
        <to type="forward">/article</to>
    </rule>

</urlrewrite>