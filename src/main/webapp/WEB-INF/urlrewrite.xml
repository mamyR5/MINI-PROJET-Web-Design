<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE urlrewrite PUBLIC "-//tuckey.org//DTD UrlRewrite 4.0//EN"
        "http://www.tuckey.org/res/dtds/urlrewrite4.0.dtd">

<urlrewrite>

    <rule>
        <from>^/test/([0-9]+)-(.*)$</from>
        <to>/test?id=$1</to>
    </rule>

    <rule>
        <from>^/article/([0-9]+)-([a-z0-9-]+)-([0-9]{4}-[0-9]{2}-[0-9]{2})$</from>
        <to>/admin/article?id=$1&amp;slug=$2&amp;date=$3</to>
    </rule>

    <rule>
        <from>^/admin/article$</from>
        <to type="forward">/admin/article</to>
    </rule>

    <rule>
        <from>^/admin/login$</from>
        <to type="forward">/login</to>
    </rule>

    <rule>
        <from>^/admin/logout$</from>
        <to type="forward">/logout</to>
    </rule>

    <rule>
        <from>^/admin/redaction$</from>
        <to type="forward">/redaction</to>
    </rule>

    <rule>
        <from>^/admin/redaction/([0-9]+)-([a-z0-9-]+)$</from>
        <to type="forward">/redaction?idArticle=$1&amp;slug=$2</to>
    </rule>

    <rule>
        <from>^/admin/home$</from>
        <to type="forward">/home</to>
    </rule>

    

</urlrewrite>